<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar">
        <activity
            android:exported="true"
            android:name=".LauncherActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:exported="false"
            android:name=".ComposeHomeActivity" />
        <activity
            android:exported="false"
            android:name=".ViewHomeActivity" />
        <activity android:exported="false" android:name=".UserApisActivity" />
        <activity android:exported="false" android:name=".CustomEventsActivity" />
        <activity android:exported="false" android:name=".OcclusionActivity" />
        <activity android:exported="false" android:name=".FullScreenOcclusionActivity" />
        <activity android:exported="false" android:name=".SessionControlsActivity" />
    </application>

</manifest>