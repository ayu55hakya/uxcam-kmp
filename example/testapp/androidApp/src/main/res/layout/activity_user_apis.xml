<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User APIs"
            android:textSize="22sp"
            android:paddingBottom="8dp" />

        <Button android:id="@+id/setIdentity" style="@style/Action" android:text="Set user identity" />
        <Button android:id="@+id/setPredefinedProp" style="@style/Action" android:text="Set predefined property (plan = premium)" />

        <TextView style="@style/Section" android:text="Custom property" />
        <EditText android:id="@+id/propKey" style="@style/Field" android:hint="Property key" />
        <EditText android:id="@+id/propValue" style="@style/Field" android:hint="Property value" />
        <Button android:id="@+id/setCustomProp" style="@style/Action" android:text="Set custom property" />

        <TextView android:id="@+id/status" style="@style/Status" />

    </LinearLayout>

</ScrollView>
