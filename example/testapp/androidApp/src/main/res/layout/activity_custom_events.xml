<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Custom Events"
            android:textSize="22sp"
            android:paddingBottom="8dp" />

        <Button android:id="@+id/eventNoProps" style="@style/Action" android:text="Event without properties" />
        <Button android:id="@+id/eventMap" style="@style/Action" android:text="Event with map properties" />
        <Button android:id="@+id/eventEmptyMap" style="@style/Action" android:text="Event with empty map" />
        <Button android:id="@+id/eventNullMap" style="@style/Action" android:text="Event with null map" />
        <Button android:id="@+id/eventJson" style="@style/Action" android:text="Event with JSON properties" />
        <Button android:id="@+id/eventEmptyJson" style="@style/Action" android:text="Event with empty JSON" />
        <Button android:id="@+id/eventNullJson" style="@style/Action" android:text="Event with null JSON" />

        <TextView style="@style/Section" android:text="Custom property event" />
        <EditText android:id="@+id/eventName" style="@style/Field" android:hint="Event name" />
        <EditText android:id="@+id/eventKey" style="@style/Field" android:hint="Property key" />
        <EditText android:id="@+id/eventValue" style="@style/Field" android:hint="Property value" />
        <Button android:id="@+id/logCustomEvent" style="@style/Action" android:text="Log custom event" />

        <TextView android:id="@+id/status" style="@style/Status" />

    </LinearLayout>

</ScrollView>
