platform :ios, '15.0'

target 'iosApp' do
  use_frameworks!

  # The shared Compose Multiplatform framework (module name `ComposeApp`), built from the
  # :shared Gradle module via the Kotlin CocoaPods plugin. Its script phase compiles the
  # Kotlin framework automatically during the Xcode build.
  pod 'shared', :path => '../shared'

  # The native iOS UXCam SDK, consumed from the locally-built xcframework
  # (uxcam/localpods/UXCam — gitignored). This provides the native symbols the shared
  # framework's UXCam wrapper calls into.
  pod 'UXCam', :path => '../../../uxcam/localpods/UXCam'
end
