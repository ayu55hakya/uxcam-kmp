platform :ios, '15.0'

target 'iosApp' do
  use_frameworks!

  # The shared Compose Multiplatform framework (Shared), built from the
  # :example:exampleApp:shared Gradle module. It re-exports the :uxcam wrapper, so this
  # single Kotlin framework provides both UxcamSetup and the UXCamKMP / UXConfig types.
  pod 'shared', :path => '../shared'

  # The native iOS UXCam SDK, consumed from the published CocoaPods release.
  pod 'UXCam', '3.8.3'
end
